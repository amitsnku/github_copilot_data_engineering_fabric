# ============================================================
# Fabric Copilot Agent — Environment Variable Template
# ============================================================
# Copy this file to .env (never commit .env to source control)
# Set these variables in your PowerShell session before running scripts:
#   $env:FABRIC_WORKSPACE_ID = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
#
# Or load from .env using:
#   Get-Content .env | ForEach-Object { if ($_ -match '^([^#][^=]+)=(.+)$') { [System.Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }
# ============================================================

# -------------------------------------------------------
# REQUIRED — Fabric Workspace
# -------------------------------------------------------
# Your Fabric workspace GUID (found in the portal URL)
FABRIC_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -------------------------------------------------------
# OPTION A: User Auth (recommended for local dev)
# -------------------------------------------------------
# Just run: az login
# Then use scripts/fabric/Get-FabricToken.ps1 to get a token
# No additional variables needed for user auth.

# -------------------------------------------------------
# OPTION B: Service Principal Auth (for CI/CD)
# -------------------------------------------------------
# App registration in Azure AD with Fabric Contributor role
FABRIC_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FABRIC_CLIENT_SECRET=your-client-secret-here
FABRIC_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -------------------------------------------------------
# OPTIONAL — Deployment Overrides
# -------------------------------------------------------
# Override the default warehouse name (default: ou_copilot_dw_poc)
# FABRIC_WAREHOUSE_NAME=my_custom_warehouse

# Override the pipeline name (default: pl_medallion_etl)
# FABRIC_PIPELINE_NAME=my_custom_pipeline
